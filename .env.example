# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API Security ───────────────────────────────────────────────────────────────
# Leave blank to disable auth (development only).
# When set, every request must include:  X-API-Key: <value>
PDF_SYNC_API_KEY=

# ── WhatsApp Automation ────────────────────────────────────────────────────────
# Comma-separated list of WhatsApp group names (exact display names).
# Each group is synced sequentially; checkpoints are tracked per group.
PDF_SYNC_WHATSAPP_GROUPS=Divya Enterprises Pax List,SIVAPURNA MOBILITY PAX List

# Set to "true" after scanning the QR code and saving the session.
# Set to "false" on first run so the browser window is visible for QR scanning.
PDF_SYNC_HEADLESS=false

# Optional — defaults shown. Leave blank to use defaults.
PDF_SYNC_WHATSAPP_SESSION_DIR=
PDF_SYNC_DOWNLOAD_DIR=
PDF_SYNC_DEBUG=false
PDF_SYNC_DEBUG_DIR=

# ── Scheduler ─────────────────────────────────────────────────────────────────
PDF_SYNC_SCHEDULER_ENABLED=true
PDF_SYNC_DAILY_TIME=03:00

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
